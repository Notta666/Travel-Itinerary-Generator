# DeepSeek API Key (Required for AI travel planning and tips generation)
# Obtain from https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# AMap (Gaode) Web Service API Key (Required for Geocoding, Places and Routing)
# Obtain from https://lbs.amap.com/
AMAP_KEY=your-amap-key-here

# FlyAI (飞猪开放平台) API Key (Optional — enables real-time flight/train/hotel pricing)
# Obtain from https://flyai.open.fliggy.com/
# Install: npm i -g @fly-ai/flyai-cli
# Configure: flyai config set FLYAI_API_KEY "your-key"
FLYAI_API_KEY=your-flyai-api-key-here

# Unsplash Access Key (Optional — enables high-quality, watermark-free travel photos)
# Obtain from https://unsplash.com/developers (free tier: 50 req/hr)
UNSPLASH_ACCESS_KEY=

# Pixabay API Key (Optional — enables free, watermark-free stock photos)
# Obtain from https://pixabay.com/api/docs/ (free tier: ~5000 req/day)
PIXABAY_API_KEY=

# CORS origins for webapp (Optional — security setting)
# Default: http://localhost:8080,http://127.0.0.1:8080
# Set to "*" to allow all origins (development only)
CORS_ORIGINS=http://localhost:8080
